{
  "name": "ChatSession",
  "type": "object",
  "properties": {
    "business_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "user",
              "assistant"
            ]
          },
          "content": {
            "type": "string"
          },
          "timestamp": {
            "type": "string"
          },
          "action_taken": {
            "type": "string"
          }
        }
      }
    },
    "last_message_at": {
      "type": "string",
      "format": "date-time"
    },
    "agent_run_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "business_id"
  ]
}