{
  "name": "Opportunity",
  "type": "object",
  "properties": {
    "business_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "pricing",
        "competitor",
        "trend",
        "review",
        "seasonal",
        "gap"
      ],
      "description": "Type of opportunity discovered"
    },
    "source": {
      "type": "string",
      "description": "Where the data came from"
    },
    "impact_score": {
      "type": "number",
      "description": "1-10 estimated revenue impact"
    },
    "urgency": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "new",
        "reviewed",
        "acted_on",
        "dismissed"
      ],
      "default": "new"
    },
    "raw_data": {
      "type": "string",
      "description": "Raw scraped data"
    },
    "suggested_action": {
      "type": "string"
    },
    "action_taken": {
      "type": "string"
    }
  },
  "required": [
    "business_id",
    "title",
    "category"
  ]
}