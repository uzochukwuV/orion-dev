{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "builds": [
    {
      "src": "dist/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "dist/**"
      }
    }
  ],
  "routes": [
    { "src": "/health", "dest": "dist/index.js" },
    { "src": "/api/(.*)", "dest": "dist/index.js" },
    { "src": "/ws/(.*)", "dest": "dist/index.js" },
    { "src": "/(.*)", "dest": "dist/index.js" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
